APP_ENV=development
APP_PORT=8080
APP_HOST=0.0.0.0
SQLITE_PATH=./data/solwhisperer.db

# Comma-separated endpoint lists. First healthy endpoint wins; manager rotates on failures.
SOLANA_RPC_TIER_A=https://api.mainnet-beta.solana.com
SOLANA_WS_TIER_A=wss://api.mainnet-beta.solana.com
SOLANA_RPC_TIER_B=https://api.mainnet-beta.solana.com
SOLANA_WS_TIER_B=wss://api.mainnet-beta.solana.com

PUMPDEV_WS_URL=wss://pumpdev.io/ws

TELEGRAM_ENABLED=true
# Required for Telegram-based authentication and Telegram notifications.
TELEGRAM_BOT_TOKEN=
# Preferred in Docker: path to mounted secret file (overrides TELEGRAM_BOT_TOKEN when set).
TELEGRAM_BOT_TOKEN_FILE=
TELEGRAM_DEFAULT_CHAT_ID=
# Preferred in Docker: path to mounted secret file (overrides TELEGRAM_DEFAULT_CHAT_ID when set).
TELEGRAM_DEFAULT_CHAT_ID_FILE=
# Public HTTPS URL registered as the Telegram Mini App launch target.
# Required when APP_ENV=production.
TELEGRAM_WEB_APP_URL=
TELEGRAM_WEB_APP_BUTTON_TEXT=Open Sol Whisperer

# Jito settings for optional MEV-protected execution.
JITO_ENABLED=true
JITO_BLOCK_ENGINE_URL=
# Optional: can be blank when using dont-front marker mode.
JITO_AUTH_KEY=
# Preferred in Docker: path to mounted secret file (overrides JITO_AUTH_KEY when set).
JITO_AUTH_KEY_FILE=
JITO_DEFAULT_TIP_SOL=0.001
# Optional tx-level front-running protection can use the marker account
# jitodontfront111111111111111111111111111111 when no auth key is configured.
SNIPE_DRY_RUN=true

# Frontend runtime (Vite)
# In production Telegram Mini App, init data comes from window.Telegram.WebApp.initData.
# For secure local testing only, you can set VITE_TELEGRAM_INIT_DATA with a valid signed init-data string.
VITE_API_BASE_URL=http://127.0.0.1:8080
VITE_TELEGRAM_INIT_DATA=
